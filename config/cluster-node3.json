{
  "mqtt": {
    "host": "0.0.0.0",
    "port": 1883,
    "max_connections": 1000,
    "max_message_size": 16384,
    "allow_anonymous": false,
    "max_queue_size": 100,
    "retain_available": true
  },
  "api": {
    "enabled": true,
    "host": "0.0.0.0",
    "port": 8080
  },
  "auth": {
    "jwt_secret": "change-me-in-production",
    "jwt_expires": 24
  },
  "database": {
    "host": "postgres",
    "port": 5432,
    "user": "postgres",
    "password": "postgres",
    "db_name": "gomqtt",
    "ssl_mode": "disable"
  },
  "plugins": {
    "enabled": true,
    "directory": "./plugins",
    "autoload": []
  },
  "logging": {
    "level": "info",
    "format": "text",
    "file": ""
  },
  "cluster": {
    "enabled": true,
    "node_id": "node3",
    "node_host": "gomqtt-node3",
    "node_port": 7946,
    "gossip_port": 7947,
    "seed_nodes": ["gomqtt-node1:7946", "gomqtt-node2:7946"],
    "sync_interval": 10
  }
} 