{
  "api": {
    "enabled": true,
    "host": "0.0.0.0",
    "port": 8080,
    "cors": {
      "enabled": true,
      "allowed_origins": ["*"],
      "allowed_methods": ["GET", "POST", "PUT", "DELETE", "OPTIONS"],
      "allowed_headers": ["Content-Type", "Authorization"]
    },
    "rate_limiting": {
      "enabled": true,
      "requests_per_second": 50,
      "burst": 100
    }
  },
  "auth": {
    "jwt_secret": "change-me-in-production",
    "jwt_expires": 24
  },
  "database": {
    "host": "postgres",
    "port": 5432,
    "user": "postgres",
    "password": "postgres",
    "db_name": "gomqtt",
    "ssl_mode": "disable"
  },
  "cluster": {
    "enabled": true,
    "node_id": "api-gateway",
    "node_host": "api-gateway",
    "node_port": 7946,
    "seed_nodes": ["gomqtt-node1:7946", "gomqtt-node2:7946", "gomqtt-node3:7946"],
    "sync_interval": 30
  },
  "logging": {
    "level": "info",
    "format": "json",
    "file": ""
  }
} 